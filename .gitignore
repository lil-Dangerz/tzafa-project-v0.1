# ============================================================
# Tzafa Project Template - Local Hygiene Guard
# ============================================================

# ------------------------------------------------------------
# Secrets / credentials / sensitive local material
# ------------------------------------------------------------
.env
.env.*
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore
*.kubeconfig
secrets/
credentials/
tokens/
local_secrets/
private/

# ------------------------------------------------------------
# Local configuration
# ------------------------------------------------------------
local_config/
*.local
*.local.*

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# ------------------------------------------------------------
# Jupyter
# ------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------
# Quarto
# ------------------------------------------------------------
.quarto/
*_files/

# ------------------------------------------------------------
# Node / frontend tooling, if ever used
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Editor / IDE
# ------------------------------------------------------------
.idea/
.vscode/settings.json
.vscode/.ropeproject

# Keep VS Code workspace recommendations if added later
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# ------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
# Logs are ignored by default because they may be large or sensitive.
# If a log must be tracked, explicitly unignore it or store a sanitized copy.
*.log

# ------------------------------------------------------------
# Generated / disposable outputs
# ------------------------------------------------------------
06_outputs/temp/
04_notebooks/outputs/temp/

# ------------------------------------------------------------
# Docker local overrides
# ------------------------------------------------------------
docker-compose.override.yml
*.pid

# ------------------------------------------------------------
# Large archives by default
# ------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# ------------------------------------------------------------
# AI tools / extensions - local generated files, caches, temp
# ------------------------------------------------------------
.codex/
.chatgpt/
.claude/
.amazonq/
.qodo/
.copilot/
.elastic-copilot/

# Generic AI temp/cache locations
.ai/
.ai_cache/
.ai_tmp/
.ai_logs/

# Nested vendor cache/temp folders
**/.codex/
**/.chatgpt/
**/.claude/
**/.amazonq/
**/.qodo/
**/.copilot/
**/.elastic-copilot/

# Logs generated by AI tools
*.ai.log
*.codex.log
*.chatgpt.log
*.claude.log
*.amazonq.log
*.qodo.log
*.copilot.log

# ------------------------------------------------------------
# Elastic / Kibana local export caution
# ------------------------------------------------------------
# Exported saved objects may be tracked if intentionally sanitized.
# These are NOT globally ignored:
# *.json
# *.ndjson
