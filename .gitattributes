# ============================================================
# Tzafa Project Template - Cross-Platform Signal Guard
# ============================================================

# ------------------------------------------------------------
# Default text normalization
# ------------------------------------------------------------
* text=auto

# ------------------------------------------------------------
# Markdown / documentation
# ------------------------------------------------------------
*.md text eol=lf
*.qmd text eol=lf
*.txt text eol=lf

# ------------------------------------------------------------
# Code / scripts
# ------------------------------------------------------------
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# ------------------------------------------------------------
# Data / structured text
# ------------------------------------------------------------
*.json text eol=lf
*.ndjson text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.csv text eol=lf
*.tsv text eol=lf
*.xml text eol=lf

# ------------------------------------------------------------
# Query files
# ------------------------------------------------------------
*.esql text eol=lf
*.kql text eol=lf
*.dsl text eol=lf
*.lucene text eol=lf
*.painless text eol=lf

# ------------------------------------------------------------
# Notebooks
# ------------------------------------------------------------
*.ipynb text eol=lf

# ------------------------------------------------------------
# Images
# ------------------------------------------------------------
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.svg text eol=lf

# ------------------------------------------------------------
# Documents / rendered reports
# ------------------------------------------------------------
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
*.html text eol=lf

# ------------------------------------------------------------
# Archives / compressed evidence bundles
# ------------------------------------------------------------
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.7z binary
*.rar binary

